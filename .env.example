# ── Intelligent Codebase Assistant — Environment Variables ──────

# Ollama (Local LLM — runs natively, NOT in Docker)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_FAST=phi3
OLLAMA_MODEL_COMPLEX=llama3:8b
OLLAMA_TIMEOUT=120

# Groq (Cloud LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=60

# Gemini (Cloud LLM)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60

# PostgreSQL
POSTGRES_URL=postgresql://codeassist:codeassist@localhost:5432/codeassist

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codeassist

# Redis
REDIS_URL=redis://localhost:6379/0

# RAG / ChromaDB Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=5
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=codebase

# Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
